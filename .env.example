# ─────────────────────────────────────────────
# Smart Risk Assessment — Environment Config
# Copy this file to .env and fill in all values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────

# Application
APP_NAME="Smart Risk Assessment"
APP_URL=http://localhost:10000
APP_ENV=local
APP_DEBUG=true
APP_KEY=

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=riskasm
DB_USER=
DB_PASSWORD=

# Session
SESSION_NAME=riskasm_session
SESSION_LIFETIME=120

# Mail (MXroute SMTP)
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@smartrisk.app
MAIL_FROM_NAME="Smart Risk Assessment"
MAIL_ENCRYPTION=tls

# SiteGround SSH (used by deploy.sh only — not loaded by the app)
DEPLOY_SSH_USER=
DEPLOY_SSH_HOST=
DEPLOY_REMOTE_PATH=
